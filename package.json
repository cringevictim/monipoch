{
  "name": "monipoch",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@10.28.2",
  "description": "Pochven Alliance Intel Platform",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "dev:api": "turbo run dev --filter=@monipoch/api",
    "dev:web": "turbo run dev --filter=@monipoch/web",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:migrate": "turbo run db:migrate --filter=@monipoch/api"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "esbuild",
      "msgpackr-extract",
      "unrs-resolver"
    ]
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "prettier": "^3.4.2",
    "turbo": "^2.0.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  }
}
