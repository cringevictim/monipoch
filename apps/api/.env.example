# Application
PORT=3000
NODE_ENV=development

# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=monipoch
DB_PASSWORD=monipoch_dev
DB_NAME=monipoch

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# EVE SSO
EVE_CLIENT_ID=your_client_id_here
EVE_CLIENT_SECRET=your_client_secret_here
EVE_CALLBACK_URL=http://localhost:3000/auth/callback
ALLOWED_ALLIANCE_ID=99013846

# JWT
JWT_SECRET=change_this_to_a_random_secret
JWT_EXPIRATION=7d

# CORS (comma-separated origins for production, leave empty for dev defaults)
CORS_ORIGIN=
# Frontend URL for OAuth redirects (leave empty to auto-detect)
FRONTEND_URL=

# Debug mode (exposes /api/debug/info route — NEVER enable in production)
DEBUG=false
